<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <meta name="csrf-token" content={csrf_token_value()}>

    <%= live_title_tag assigns[:page_title] || "EdgeOsCloud", suffix: "" %>

    <!-- Custom fonts for this template-->
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="/css/sb-admin-2.css" rel="stylesheet">

    <style>
      /* ── Logo bleed fix (tablet + collapsed sidebar) ── */
      .sidebar-brand {
        overflow: hidden;
        padding: 1rem 0.5rem;
      }
      .sidebar-brand img {
        max-width: 100%;
        height: auto;
        object-fit: contain;
      }

      /* ── Phone sidebar: hidden by default, overlay when .toggled ── */
      /* On phone we invert the SB Admin 2 toggle logic:
         default = hidden (width 0), .toggled = open (14rem overlay) */
      @media (max-width: 575.98px) {
        #accordionSidebar {
          position: fixed !important;
          top: 0; left: 0;
          height: 100vh;
          z-index: 1055;
          width: 0 !important;
          overflow: hidden !important;
          transition: width 0.25s ease;
        }
        #accordionSidebar.toggled {
          width: 14rem !important;
          overflow-y: auto !important;
        }
        /* Full-width content since sidebar is overlaid */
        #wrapper #content-wrapper {
          margin-left: 0 !important;
        }
      }

      /* Backdrop for mobile sidebar */
      #sidebar-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 1054;
        transition: opacity 0.25s;
      }
      #sidebar-backdrop.show { display: block; }

      /* ── Phone content adjustments ── */
      @media (max-width: 575.98px) {
        .container-fluid { padding-left: 0.75rem; padding-right: 0.75rem; }
        h1.h3 { font-size: 1.15rem; }
        /* Search bar full-width */
        #edge-search { max-width: 100% !important; }
        #edge-search + div { max-width: 100% !important; }
        /* Camera feed shorter on phone */
        #feed-placeholder { height: 220px !important; }
        /* Topbar tighter */
        .topbar.shadow { padding-left: 0.5rem; padding-right: 0.5rem; }
      }

      /* ── Tablet: keep icon sidebar but fix brand ── */
      @media (max-width: 767.98px) {
        .sidebar-brand img { max-height: 36px; }
      }
    </style>
    <script defer phx-track-static type="text/javascript" src={Routes.static_path(@conn, "/assets/app.js")}></script>

    <!-- Favicons-->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="manifest" href="/images/site.webmanifest">

    <!-- Bootstrap core JavaScript-->
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript-->
    <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages-->
    <script src="/js/sb-admin-2.min.js"></script>
    <script>
      (function() {
        var btn     = document.getElementById('sidebarToggleTop');
        var sidebar = document.getElementById('accordionSidebar');
        var backdrop = document.getElementById('sidebar-backdrop');
        if (!btn || !sidebar || !backdrop) return;

        // Watch the sidebar's class list — SB Admin 2 toggles .toggled on it.
        // On phone we invert: .toggled = open, no .toggled = closed.
        var observer = new MutationObserver(function() {
          if (window.innerWidth >= 576) return;
          if (sidebar.classList.contains('toggled')) {
            backdrop.classList.add('show');
          } else {
            backdrop.classList.remove('show');
          }
        });
        observer.observe(sidebar, { attributes: true, attributeFilter: ['class'] });

        // Tapping the backdrop triggers the button to reverse the toggle
        backdrop.addEventListener('click', function() {
          btn.click();
        });

        // Close sidebar when a nav link is tapped on phone
        sidebar.querySelectorAll('.nav-link').forEach(function(link) {
          link.addEventListener('click', function() {
            if (window.innerWidth < 576 && sidebar.classList.contains('toggled')) {
              btn.click();
            }
          });
        });
      })();
    </script>
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">

            <!-- Sidebar - Brand -->
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="https://edge.sailoi.com/">
                <img src="/images/white-logo-small.png" alt="EdgeOS Logo"/>
            </a>

            <!-- Divider -->
            <hr class="sidebar-divider my-0">

            <!-- Divider -->
            <hr class="sidebar-divider">

            <!-- Heading -->
            <div class="sidebar-heading">
                Menu
            </div>

            <li class="nav-item">
                <a class="nav-link" href="/edges">
                    <i class="fas fa-fw fa-cubes"></i>
                    <span>Devices</span></a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/teams">
                    <i class="fas fa-fw fa-users"></i>
                    <span>Teams</span></a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/sessions">
                    <i class="fas fa-fw fa-history"></i>
                    <span>Activity</span></a>
            </li>

            <!-- Divider -->
            <hr class="sidebar-divider d-none d-md-block">

            <li class="nav-item">
                <a class="nav-link" target="_blank" href="https://github.com/wingchen/edge-os/issues">
                    <i class="fas fa-fw fa-users"></i>
                    <span>Support and Community</span></a>
            </li>

            <li class="nav-item">
                <a class="nav-link" target="_blank" href="https://github.com/wingchen/edge-os">
                    <i class="fas fa-fw fa-code-branch"></i>
                    <span>Source Code</span></a>
            </li>
        </ul>
        <!-- End of Sidebar -->

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">

                    <!-- Sidebar Toggle (Topbar) -->
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <!-- Topbar Navbar -->
                    <ul class="navbar-nav ml-auto">

                        <div class="topbar-divider d-none d-sm-block"></div>

                        <!-- Nav Item - User Information -->
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small"><%= @current_user.name %></span>
                                <i class="fas fa-user-circle"></i>
                            </a>
                            <!-- Dropdown - User Information -->
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in"
                                aria-labelledby="userDropdown">
                                <a class="dropdown-item" href="/me">
                                    <i class="fas fa-id-badge fa-sm fa-fw mr-2 text-gray-400"></i>
                                    My Account
                                </a>
                                <a class="dropdown-item" href="#" data-toggle="modal" data-target="#logoutModal">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Logout
                                </a>
                            </div>
                        </li>

                    </ul>

                </nav>
                <!-- End of Topbar -->

                <!-- Begin Page Content -->
                <div class="container-fluid">

                    <%= @inner_content %>

                </div>
                <!-- /.container-fluid -->

            </div>
            <!-- End of Main Content -->

            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>EdgeOS: Open-source with MIT License</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- Mobile sidebar backdrop -->
    <div id="sidebar-backdrop"></div>

    <!-- Logout Modal-->
    <div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <div class="modal-body">Select "Logout" below if you are ready to end your current operation.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <a class="btn btn-primary" href="/logout">Logout</a>
                </div>
            </div>
        </div>
    </div>
</body>

</html>