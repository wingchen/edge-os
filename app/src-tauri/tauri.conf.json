{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EdgeOS",
  "version": "0.1.0",
  "identifier": "com.sailoi.edgeos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EdgeOS",
        "visible": false,
        "width": 1,
        "height": 1
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../../edge/target/release/edge-os-edge"
    ],
    "resources": {
      "gstreamer/lib/**/*":     "gstreamer/lib/",
      "gstreamer/plugins/**/*": "gstreamer/plugins/"
    },
    "macOS": {
      "infoPlist": "./Info.plist",
      "minimumSystemVersion": "12.0",
      "dmg": {
        "appPosition":               { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize":                { "width": 660, "height": 400 }
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libgstreamer1.0-0",
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-nice"
        ]
      },
      "rpm": {
        "depends": [
          "gstreamer1",
          "gstreamer1-plugins-base",
          "gstreamer1-plugins-good",
          "gstreamer1-plugins-bad-free",
          "libnice"
        ]
      }
    }
  }
}
