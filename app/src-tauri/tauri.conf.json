{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EdgeOS",
  "version": "0.1.0",
  "identifier": "com.sailoi.edgeos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EdgeOS",
        "visible": false,
        "width": 1,
        "height": 1
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../../edge/target/release/edge-os-edge"
    ],
    "macOS": {
      "infoPlist": {
        "LSUIElement": true,
        "NSHighResolutionCapable": true
      }
    }
  }
}
